generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  FACULTY
  ADMIN
  COLLEGE
}

enum AttendanceMethod {
  QR
  GEOFENCING
  MANUAL
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum ResourceCategory {
  NOTES
  ASSIGNMENTS
  LAB_FILES
  QUESTION_PAPERS
  STUDY_MATERIAL
  RECORDED_LECTURES
  DEPARTMENT
}

enum ComplaintType {
  HOSTEL
  MESS
  INFRASTRUCTURE
  ACADEMIC
  GENERAL
}

enum ComplaintStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

enum NoticeCategory {
  ACADEMIC
  ADMINISTRATIVE
  EMERGENCY
}

enum ItemType {
  LOST
  FOUND
}

enum MessageScope {
  DIRECT
  GROUP
}

enum NotificationType {
  ATTENDANCE
  EVENT
  ANNOUNCEMENT
  COMPLAINT
  RESOURCE
  GENERAL
}

enum EventRegistrationStatus {
  REGISTERED
  WAITLISTED
  CANCELLED
}

model User {
  id                 String              @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  email              String              @unique
  passwordHash       String
  role               Role
  avatarUrl          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  studentProfile     StudentProfile?
  facultyProfile     FacultyProfile?
  uploadedResources  Resource[]          @relation("UploadedResources")
  createdNotices     Notice[]            @relation("NoticeCreator")
  createdEvents      Event[]             @relation("EventCreator")
  eventRegistrations EventRegistration[]
  eventBookmarks     EventBookmark[]
  complaintsRaised   Complaint[]         @relation("ComplaintOwner")
  complaintsAssigned Complaint[]         @relation("ComplaintAssignee")
  complaintResponses ComplaintResponse[]
  lostFoundItems     LostFoundItem[]
  sharedNotes        SharedNote[]
  noteLikes          NoteLike[]
  noteBookmarks      NoteBookmark[]
  sentMessages       Message[]           @relation("MessageSender")
  receivedMessages   Message[]           @relation("MessageReceiver")
  groupMemberships   GroupMembership[]
  createdGroups      PeerGroup[]         @relation("GroupCreator")
  notifications      Notification[]
}

model Department {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  name        String           @unique
  code        String           @unique
  createdAt   DateTime         @default(now())
  students    StudentProfile[]
  faculty     FacultyProfile[]
  subjects    Subject[]
  resources   Resource[]
  events      Event[]
  sharedNotes SharedNote[]
  groups      PeerGroup[]
  buildings   Building[]
  hostelRooms HostelRoom[]
}

model Subject {
  id                 String              @id @default(auto()) @map("_id") @db.ObjectId
  code               String              @unique
  title              String
  semester           Int
  departmentId       String @db.ObjectId
  department         Department          @relation(fields: [departmentId], references: [id])
  enrollments        Enrollment[]
  facultyLinks       SubjectFaculty[]
  attendanceSessions AttendanceSession[]
  resources          Resource[]
  sharedNotes        SharedNote[]
}

model StudentProfile {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  userId           String @db.ObjectId            @unique
  rollNumber       String            @unique
  semester         Int
  section          String?
  departmentId     String @db.ObjectId
  user             User              @relation(fields: [userId], references: [id])
  department       Department        @relation(fields: [departmentId], references: [id])
  enrollments      Enrollment[]
  attendanceRecords AttendanceRecord[]
  hostelAllocation HostelAllocation?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model FacultyProfile {
  id                 String              @id @default(auto()) @map("_id") @db.ObjectId
  userId             String @db.ObjectId              @unique
  employeeCode       String              @unique
  designation        String
  departmentId       String @db.ObjectId
  user               User                @relation(fields: [userId], references: [id])
  department         Department          @relation(fields: [departmentId], references: [id])
  subjects           SubjectFaculty[]
  attendanceSessions AttendanceSession[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model SubjectFaculty {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  subjectId        String @db.ObjectId
  facultyProfileId String @db.ObjectId
  createdAt        DateTime       @default(now())
  subject          Subject        @relation(fields: [subjectId], references: [id])
  facultyProfile   FacultyProfile @relation(fields: [facultyProfileId], references: [id])

  @@unique([subjectId, facultyProfileId])
}

model Enrollment {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  subjectId        String @db.ObjectId
  studentProfileId String @db.ObjectId
  createdAt        DateTime       @default(now())
  subject          Subject        @relation(fields: [subjectId], references: [id])
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])

  @@unique([subjectId, studentProfileId])
}

model AttendanceSession {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  subjectId        String @db.ObjectId
  facultyProfileId String @db.ObjectId
  sessionDate      DateTime
  startTime        DateTime
  endTime          DateTime
  method           AttendanceMethod
  qrToken          String?           @unique
  geoLat           Float?
  geoLng           Float?
  radiusMeters     Int?
  isActive         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  subject          Subject           @relation(fields: [subjectId], references: [id])
  facultyProfile   FacultyProfile    @relation(fields: [facultyProfileId], references: [id])
  records          AttendanceRecord[]
}

model AttendanceRecord {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  sessionId        String @db.ObjectId
  studentProfileId String @db.ObjectId
  status           AttendanceStatus  @default(ABSENT)
  method           AttendanceMethod?
  markedAt         DateTime?
  session          AttendanceSession @relation(fields: [sessionId], references: [id])
  studentProfile   StudentProfile    @relation(fields: [studentProfileId], references: [id])

  @@unique([sessionId, studentProfileId])
}

model Resource {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  description  String
  category     ResourceCategory
  subjectId    String? @db.ObjectId
  departmentId String? @db.ObjectId
  semester     Int?
  fileUrl      String
  uploaderId   String @db.ObjectId
  approved     Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  subject      Subject?         @relation(fields: [subjectId], references: [id])
  department   Department?      @relation(fields: [departmentId], references: [id])
  uploader     User             @relation("UploadedResources", fields: [uploaderId], references: [id])
}

model Notice {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  content      String
  category     NoticeCategory
  targetRole   Role?
  departmentId String? @db.ObjectId
  subjectId    String? @db.ObjectId
  createdById  String @db.ObjectId
  createdAt    DateTime       @default(now())
  createdBy    User           @relation("NoticeCreator", fields: [createdById], references: [id])
}

model Event {
  id            String              @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String
  date          DateTime
  location      String
  organizer     String
  posterUrl     String?
  capacity      Int?
  departmentId  String? @db.ObjectId
  createdById   String @db.ObjectId
  createdAt     DateTime            @default(now())
  department    Department?         @relation(fields: [departmentId], references: [id])
  createdBy     User                @relation("EventCreator", fields: [createdById], references: [id])
  registrations EventRegistration[]
  bookmarks     EventBookmark[]
}

model EventRegistration {
  id        String                  @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String @db.ObjectId
  userId    String @db.ObjectId
  status    EventRegistrationStatus @default(REGISTERED)
  createdAt DateTime                @default(now())
  event     Event                   @relation(fields: [eventId], references: [id])
  user      User                    @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

model EventBookmark {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String @db.ObjectId
  userId    String @db.ObjectId
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

model Complaint {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  description  String
  type         ComplaintType
  status       ComplaintStatus   @default(PENDING)
  ownerId      String @db.ObjectId
  assignedToId String? @db.ObjectId
  hostelRoomId String? @db.ObjectId
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  owner        User              @relation("ComplaintOwner", fields: [ownerId], references: [id])
  assignedTo   User?             @relation("ComplaintAssignee", fields: [assignedToId], references: [id])
  hostelRoom   HostelRoom?       @relation(fields: [hostelRoomId], references: [id])
  responses    ComplaintResponse[]
}

model ComplaintResponse {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  complaintId String @db.ObjectId
  authorId    String @db.ObjectId
  message     String
  createdAt   DateTime  @default(now())
  complaint   Complaint @relation(fields: [complaintId], references: [id])
  author      User      @relation(fields: [authorId], references: [id])
}

model HostelRoom {
  id           String             @id @default(auto()) @map("_id") @db.ObjectId
  block        String
  roomNumber   String
  capacity     Int
  departmentId String? @db.ObjectId
  createdAt    DateTime           @default(now())
  department   Department?        @relation(fields: [departmentId], references: [id])
  allocations  HostelAllocation[]
  complaints   Complaint[]

  @@unique([block, roomNumber])
}

model HostelAllocation {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  roomId           String @db.ObjectId
  studentProfileId String @db.ObjectId         @unique
  allocatedAt      DateTime       @default(now())
  isActive         Boolean        @default(true)
  room             HostelRoom     @relation(fields: [roomId], references: [id])
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
}

model LostFoundItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        ItemType
  title       String
  description String
  location    String
  contactInfo String
  postedById  String @db.ObjectId
  isResolved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  postedBy    User     @relation(fields: [postedById], references: [id])
}

model SharedNote {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  description  String
  fileUrl      String
  subjectId    String? @db.ObjectId
  departmentId String? @db.ObjectId
  semester     Int?
  uploaderId   String @db.ObjectId
  createdAt    DateTime     @default(now())
  uploader     User         @relation(fields: [uploaderId], references: [id])
  subject      Subject?     @relation(fields: [subjectId], references: [id])
  department   Department?  @relation(fields: [departmentId], references: [id])
  likes        NoteLike[]
  bookmarks    NoteBookmark[]
}

model NoteLike {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  noteId    String @db.ObjectId
  userId    String @db.ObjectId
  createdAt DateTime   @default(now())
  note      SharedNote @relation(fields: [noteId], references: [id])
  user      User       @relation(fields: [userId], references: [id])

  @@unique([noteId, userId])
}

model NoteBookmark {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  noteId    String @db.ObjectId
  userId    String @db.ObjectId
  createdAt DateTime   @default(now())
  note      SharedNote @relation(fields: [noteId], references: [id])
  user      User       @relation(fields: [userId], references: [id])

  @@unique([noteId, userId])
}

model PeerGroup {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  description  String
  departmentId String? @db.ObjectId
  semester     Int?
  createdById  String @db.ObjectId
  createdAt    DateTime          @default(now())
  department   Department?       @relation(fields: [departmentId], references: [id])
  createdBy    User              @relation("GroupCreator", fields: [createdById], references: [id])
  memberships  GroupMembership[]
  messages     Message[]         @relation("GroupMessages")
}

model GroupMembership {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  groupId  String @db.ObjectId
  userId   String @db.ObjectId
  joinedAt DateTime  @default(now())
  group    PeerGroup @relation(fields: [groupId], references: [id])
  user     User      @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model Message {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  scope      MessageScope
  content    String
  senderId   String @db.ObjectId
  receiverId String? @db.ObjectId
  groupId    String? @db.ObjectId
  createdAt  DateTime     @default(now())
  sender     User         @relation("MessageSender", fields: [senderId], references: [id])
  receiver   User?        @relation("MessageReceiver", fields: [receiverId], references: [id])
  group      PeerGroup?   @relation("GroupMessages", fields: [groupId], references: [id])
}

model Building {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  type         String
  code         String      @unique
  description  String
  floor        String?
  mapX         Float
  mapY         Float
  departmentId String? @db.ObjectId
  department   Department? @relation(fields: [departmentId], references: [id])
}

model Notification {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  userId    String @db.ObjectId
  type      NotificationType
  title     String
  message   String
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
}

